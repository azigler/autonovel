{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "hooks/session-start.sh",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "hooks/lint-on-write.sh",
						"timeout": 30
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "hooks/pre-commit-checks.sh",
						"timeout": 120
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "hooks/pre-compact.sh",
						"timeout": 10
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && bash hooks/check-status.sh"
					}
				]
			}
		],
		"SubagentStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "hooks/session-start.sh",
						"timeout": 10
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "hooks/session-end.sh",
						"timeout": 10
					}
				]
			}
		],
		"TaskCompleted": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "hooks/task-completed.sh",
						"timeout": 60
					}
				]
			}
		],
		"TeammateIdle": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "hooks/teammate-idle.sh",
						"timeout": 30
					}
				]
			}
		]
	}
}
